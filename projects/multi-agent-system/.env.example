# 多Agent协作系统 - 环境变量配置

# ============ LLM配置 ============
# OpenAI API密钥（必填）
OPENAI_API_KEY=your-api-key-here

# API基础URL（可选，用于兼容接口）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（可选）
# LLM_MODEL=gpt-4

# ============ 系统配置 ============
# API服务端口
API_PORT=8000

# 日志级别
LOG_LEVEL=INFO

# ============ 记忆配置 ============
# Redis连接URL
REDIS_URL=redis://localhost:6379/0

# 向量数据库路径
VECTOR_DB_PATH=./data/chroma

# ============ 上下文配置 ============
# 最大上下文tokens
MAX_CONTEXT_TOKENS=16000
